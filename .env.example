# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Claude API ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Redis (Phase 2 — BullMQ queue backend) ────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Runtime ───────────────────────────────────────────────────
WORKSPACE_DIR=./workspace
# PROJECT_ROOT=.                  # Auto-detected from src/config.ts location

# ── Budget ────────────────────────────────────────────────────
# BUDGET_MONTHLY=1000             # Monthly API budget in dollars

# ── Logging ───────────────────────────────────────────────────
# LOG_LEVEL=info                  # trace|debug|info|warn|error|fatal|silent
# LOG_FORMAT=pretty               # json|pretty

# ── Concurrency ──────────────────────────────────────────────
# MAX_PARALLEL_AGENTS=3           # Max concurrent agent executions
# MAX_TOOL_ITERATIONS=10          # Max tool call iterations per agent execution

# ── Google OAuth (Phase 4a — GA4, Search Console, GTM) ──────
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Scopes needed: analytics.readonly, webmasters.readonly, tagmanager.readonly
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ── PageSpeed Insights (Phase 4a) ───────────────────────────
# Get this from Google Cloud Console → APIs & Services → Credentials → API Keys
# Enable "PageSpeed Insights API" and "Chrome UX Report API" in your project
# PAGESPEED_API_KEY=
